#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

python_cmd=()

select_python() {
  local -a candidate=("$@")
  if [[ "${#candidate[@]}" -eq 0 ]]; then
    return 1
  fi

  if ! command -v "${candidate[0]}" >/dev/null 2>&1; then
    return 1
  fi

  if "${candidate[@]}" -c "import sys" >/dev/null 2>&1; then
    python_cmd=("${candidate[@]}")
    return 0
  fi

  return 1
}

if [[ "${OS:-}" == "Windows_NT" ]]; then
  select_python py -3 \
    || select_python py.exe -3 \
    || select_python python \
    || select_python python.exe \
    || select_python python3 \
    || select_python python3.exe
else
  select_python python3 || select_python python || select_python py -3
fi

if [[ "${#python_cmd[@]}" -gt 0 ]]; then
  "${python_cmd[@]}" "tools/krt.py" pre-commit
  exit $?
fi

if command -v pwsh >/dev/null 2>&1; then
  ps_cmd="pwsh"
elif command -v pwsh.exe >/dev/null 2>&1; then
  ps_cmd="pwsh.exe"
elif command -v powershell >/dev/null 2>&1; then
  ps_cmd="powershell"
elif command -v powershell.exe >/dev/null 2>&1; then
  ps_cmd="powershell.exe"
else
  echo "PowerShell not found. Cannot run KRT pre-commit checks." >&2
  exit 1
fi

ps_script_path="$repo_root/tools/pre-commit.ps1"
ps_cmd_lower="$(printf '%s' "$ps_cmd" | tr '[:upper:]' '[:lower:]')"
is_windows_host_ps=0

if [[ "$ps_cmd_lower" == *".exe" ]] || [[ "$ps_cmd_lower" == "powershell" ]]; then
  is_windows_host_ps=1
fi

if [[ "$is_windows_host_ps" -eq 1 ]]; then
  if command -v cygpath >/dev/null 2>&1; then
    ps_script_path="$(cygpath -w "$ps_script_path")"
  elif command -v wslpath >/dev/null 2>&1; then
    ps_script_path="$(wslpath -w "$ps_script_path")"
  fi
fi

"$ps_cmd" -NoProfile -ExecutionPolicy Bypass -File "$ps_script_path"
